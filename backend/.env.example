# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=traceguard_db

# CORS Configuration
CORS_ORIGINS=*

# JWT Configuration - CHANGE IN PRODUCTION
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Termii SMS Integration (Optional)
TERMII_API_KEY=your_termii_api_key_here
TERMII_SENDER_ID=your_sender_id
TERMII_BASE_URL=https://api.ng.termii.com

# Paystack Payment Integration (Optional)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Emergent LLM Key for AI Features (Optional)
EMERGENT_LLM_KEY=sk-emergent-your_key_here
