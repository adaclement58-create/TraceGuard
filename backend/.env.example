# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=traceguard_db

# CORS Configuration
CORS_ORIGINS=*

# JWT Configuration - CHANGE IN PRODUCTION
JWT_SECRET=change_this_to_a_secure_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Termii SMS Integration (Optional)
TERMII_API_KEY=your_termii_api_key_here
TERMII_SENDER_ID=your_sender_id
TERMII_BASE_URL=https://api.ng.termii.com

# Paystack Payment Integration (Optional)
# Get keys from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

# Emergent LLM Key for AI Features (Optional)
EMERGENT_LLM_KEY=your_emergent_llm_key_here
